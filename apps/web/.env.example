# OpenNapse Environment Variables
# Copy this file to .env.local and fill in your values.
# The app works fully offline without any of these set.

# ─── Supabase (optional: enables auth, teams, cloud sync, AI gateway) ───
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Billing (optional: enables hosted plan checks, Stripe checkout) ───
# Set to your Supabase Edge Function URL, e.g.
#   https://YOUR_REF.supabase.co/functions/v1/billing
# The private opennapse-billing repo provides the billing wrapper.
VITE_BILLING_URL=

# ─── Team workspaces (optional: enable team workspace creation) ───
# Set to "true" to allow creating team/shared workspaces.
# VITE_ENABLE_TEAM_WORKSPACES=true

# ─── Hosted AI safety gate (Supabase Edge Function secret, not VITE_*) ───
# Keep false until server-side atomic allowance accounting is deployed.
# HOSTED_AI_ENABLED=false

# ─── Notes ───
# - Never put service-role keys or provider API keys here.
# - VITE_* variables are exposed to the browser bundle.
# - Provider keys are entered per-session in the Settings UI
#   and stored in Supabase Vault (server-side only).
